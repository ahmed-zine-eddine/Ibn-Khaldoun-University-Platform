# ─────────────────────────────────────────────────────────────
# University Management System — Docker Compose env template
# Copy to .env and edit before running `docker compose up`.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=university_pfe

# ── Backend (Node) ──────────────────────────────────────────
NODE_ENV=production

# CHANGE THESE — must be at least 32 chars each
JWT_ACCESS_SECRET=replace-me-with-a-32+char-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-32+char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=10
APP_BASE_URL=http://localhost:5000

# Comma-separated origins allowed by the backend's CORS layer.
CLIENT_URLS=http://localhost:3000

# ── Email (optional — leave blank to disable email sending) ─
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── External AI keys (optional) ─────────────────────────────
GROQ_API_KEY=

# ── Frontend build-time vars (baked into the bundle) ────────
# Public URLs the browser will hit. For local Docker compose,
# the defaults below work; for prod, set these to your domain.
REACT_APP_API_URL=http://localhost:5000/api/v1
REACT_APP_AI_URL=http://localhost:5001

# ── AI service ──────────────────────────────────────────────
AI_LOG_LEVEL=INFO
